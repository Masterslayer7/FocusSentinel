{
  "name": "focussentinel",
  "version": "0.1.0",
  "description": "Privacy-first, local-only digital study evaluator",
  "main": "dist/main/main.js",
  "scripts": {
    "build": "tsc && vite build",
    "watch": "tsc -w",
    "dev": "tsc && concurrently -k \"vite\" \"ELECTRON_IS_DEV=1 electron .\"",
    "start": "npm run build && electron .",
    "test:ui": "vitest run"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.11.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "electron": "^30.0.0",
    "jsdom": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
